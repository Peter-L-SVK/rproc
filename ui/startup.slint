import { Theme } from "theme.slint";
import { Card, SmallButton, SearchBox, Toggle } from "widgets.slint";
import { StartupRow } from "structs.slint";
import { ScrollView } from "std-widgets.slint";

component StartupCard inherits Card {
    in property <StartupRow> data;
    in property <bool> locked-section;
    callback toggle(int, bool);
    callback properties(int);
    callback open-desktop(int);
    callback context(int, length, length);
    height: self.preferred-height;
    // Below the toggle/buttons so they keep their clicks; catches double-click
    // and right-click on the rest of the card.
    ta := TouchArea {
        mouse-cursor: pointer;
        double-clicked => { root.properties(data.index); }
        pointer-event(e) => {
            if (e.button == PointerEventButton.right && e.kind == PointerEventKind.down) {
                root.context(data.index, self.absolute-position.x + self.mouse-x, self.absolute-position.y + self.mouse-y);
            }
        }
    }
    HorizontalLayout {
        padding: 10px;
        spacing: 8px;
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            HorizontalLayout {
                spacing: 6px;
                Text { text: data.name; font-weight: 700; font-size: 14px; color: Theme.text; vertical-alignment: center; }
                if data.locked: Text { text: "protected"; color: Theme.warn; font-size: 11px; font-weight: 700; vertical-alignment: center; }
                Rectangle { horizontal-stretch: 1; }
            }
            if data.comment != "": Text { text: data.comment; color: Theme.text-dim; font-size: 11px; }
            Text { text: data.badge; color: Theme.text-dim; font-size: 11px; }
            Text { text: data.exec; color: Theme.text-dim; font-size: 11px; font-family: "monospace"; overflow: elide; }
        }
        VerticalLayout {
            alignment: center;
            spacing: 4px;
            Toggle {
                text: data.locked ? "Protected" : (data.enabled ? "Enabled" : "Disabled");
                checked: data.enabled && !data.locked;
                enabled: !data.locked;
                toggled => { root.toggle(data.index, !data.enabled); }
            }
            HorizontalLayout {
                alignment: end;
                spacing: 4px;
                Text { text: data.boot-time; color: data.boot-known ? Theme.text : Theme.text-dim; font-family: "monospace"; vertical-alignment: center; }
            }
            HorizontalLayout {
                alignment: end;
                spacing: 4px;
                if data.is-desktop: SmallButton { text: "Open"; clicked => { root.open-desktop(data.index); } }
                SmallButton { text: "Properties"; clicked => { root.properties(data.index); } }
            }
        }
    }
}

export component Startup inherits VerticalLayout {
    in property <[StartupRow]> normal;
    in property <[StartupRow]> critical;
    in property <string> error;
    in-out property <string> filter;

    callback reload();
    callback filter-changed(string);
    callback toggle(int, bool);
    callback properties(int);
    callback open-desktop(int);
    callback row-context(int, length, length);

    spacing: 6px;

    HorizontalLayout {
        spacing: 8px;
        Text { text: "Startup apps"; font-size: 20px; font-weight: 700; color: Theme.text; vertical-alignment: center; }
        Rectangle { horizontal-stretch: 1; }
        SmallButton { text: "⟳"; clicked => { root.reload(); } }
        SearchBox { placeholder: "Filter by name or time (e.g. >0.5)"; text <=> root.filter; edited(t) => { root.filter-changed(t); } }
    }
    Text {
        text: "Sorted by boot time (descending). Units managed by systemd dependencies are protected and cannot be disabled.";
        color: Theme.text-dim;
        wrap: word-wrap;
    }
    if root.error != "": Text { text: root.error; color: Theme.err; }

    ScrollView {
        vertical-stretch: 1;
        VerticalLayout {
            spacing: 6px;
            padding-right: 12px;
            if root.normal.length > 0: Text { text: "Startup apps & services"; color: Theme.text; font-weight: 700; }
            for e in root.normal: StartupCard {
                data: e;
                toggle(i, en) => { root.toggle(i, en); }
                properties(i) => { root.properties(i); }
                open-desktop(i) => { root.open-desktop(i); }
                context(i, x, y) => { root.row-context(i, x, y); }
            }
            if root.critical.length > 0: Rectangle { height: 10px; }
            if root.critical.length > 0: Text { text: "Protected by systemd"; color: Theme.warn; font-weight: 700; }
            if root.critical.length > 0: Text {
                text: "These services are pulled in by dependency (state: static/generated/alias). `systemctl disable` has no effect on them.";
                color: Theme.text-dim; font-size: 11px; wrap: word-wrap;
            }
            for e in root.critical: StartupCard {
                data: e;
                locked-section: true;
                toggle(i, en) => { root.toggle(i, en); }
                properties(i) => { root.properties(i); }
                open-desktop(i) => { root.open-desktop(i); }
                context(i, x, y) => { root.row-context(i, x, y); }
            }
            Rectangle { height: 6px; }
        }
    }
}
