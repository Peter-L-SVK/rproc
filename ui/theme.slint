// Palette mirroring src/theme.rs (Windows 11 "mica" dark look). Kept in one
// global so every component reads the same colors and the look stays 1:1 with
// the previous egui build.
export global Theme {
    out property <color> accent: #60CDFF;
    out property <color> bg: #1F1F1F;
    out property <color> sidebar-bg: #2A2A2A;
    out property <color> panel-bg: #262626;
    out property <color> card-bg: #2E2E2E;
    out property <color> hover-bg: #383838;
    out property <color> active-bg: #444444;
    out property <color> text: #E6E6E6;
    out property <color> text-dim: #9A9A9A;
    out property <color> text-faint: #5A5A5A;

    // Hairline separators (table columns, etc.).
    out property <color> divider: #ffffff1A;

    out property <color> graph-cpu: #39A7FF;
    out property <color> graph-ram: #B46AFF;
    out property <color> graph-disk: #4EE0B3;
    out property <color> graph-net: #FFB04E;
    out property <color> graph-gpu: #FF5C8A;

    out property <color> ok: #55D17C;
    out property <color> warn: #FFC44D;
    out property <color> err: #FF6B6B;

    // Translucent accent used for selected rows / cards.
    out property <brush> selection-bg: #60CDFF26;
}
